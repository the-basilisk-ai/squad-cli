{
  "name": "@squadai/cli",
  "version": "0.4.0",
  "description": "Squad AI CLI - Product strategy management for AI agents and humans",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-basilisk-ai/squad-cli.git"
  },
  "homepage": "https://github.com/the-basilisk-ai/squad-cli#readme",
  "bugs": {
    "url": "https://github.com/the-basilisk-ai/squad-cli/issues"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "type": "module",
  "bin": {
    "squad": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "format": "biome check .",
    "format:fix": "biome check --write .",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:check": "graphql-codegen --config codegen.ts --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "commander": "^15.0.0",
    "graphql": "^17.0.2",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/client-preset": "^6.1.0",
    "@types/node": "^22.15.0",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.9"
  },
  "resolutions": {
    "**/knip/picomatch": "4.0.4",
    "**/tinyglobby/picomatch": "4.0.4",
    "**/esbuild": "0.28.1"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
